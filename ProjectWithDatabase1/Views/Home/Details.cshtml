@model ProjectWithDatabase1.Models.Student

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Student</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Roll)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.StudentName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.StudentGender)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.StudentDob)
        </dd>
         
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Roll" class="btn btn-warning">Edit</a> |
    <a asp-action="ListData" class="btn btn-secondary">Back to List</a>
</div>